# =============================================================================
# Water Awareness Foundation — environment variables
# =============================================================================
# The app runs WITHOUT any of these set. Without Supabase you simply lose the
# cache layer (every request hits EPA SDWIS live) and newsletter signups are
# logged to stdout instead of persisted.

# --- Public site config ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (optional but recommended for production) ---
# Get these from https://app.supabase.com → Project Settings → API
# Then run lib/db/schema.sql in the Supabase SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (optional — emails fall back to console log if missing) ---
# https://resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_NEWSLETTER=Water Awareness Foundation <newsletter@wateraware.org>

# --- EWG scraper override (set to 1 to disable EWG fetches) ---
WAF_DISABLE_EWG=

# --- Analytics (optional) ---
# Plausible: just set the domain string used by the script tag
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Error monitoring (optional) ---
# Sentry DSN — leave blank to disable
NEXT_PUBLIC_SENTRY_DSN=
